+
+// Qt headers pull in many system APIs that ScummVM otherwise forbids.
+#define FORBIDDEN_SYMBOL_ALLOW_ALL
+
+#include "common/scummsys.h"
+
+#if defined(POSIX) && defined(USE_SYSDIALOGS) && defined(USE_QT)
+
+#include "backends/dialogs/qt/qt-dialogs.h"
+
+#include "common/config-manager.h"
+#include "common/events.h"
+#include "common/translation.h"
+
+#include <locale.h>
+
+#include <QApplication>
+#include <QFileDialog>
+#include <QDir>
+#include <QTimer>
+
+namespace {
+
+QApplication *ensureQtApplication() {
+	if (QCoreApplication::instance())
+		return qobject_cast<QApplication *>(QCoreApplication::instance());
+
+	// QApplication keeps references to argc/argv for its lifetime.
+	static int argc = 1;
+	static char appName[] = "scummvm";
+	static char *argv[] = { appName, nullptr };
+
+	// Qt 6 enables high-DPI scaling by default.
+	return new QApplication(argc, argv);
+}
+
+} // End of anonymous namespace
+
+Common::DialogManager::DialogResult QtDialogManager::showFileBrowser(const Common::U32String &title, Common::FSNode &choice, bool isDirBrowser) {
+	QApplication *app = ensureQtApplication();
+	if (!app)
+		return kDialogError;
+
+	DialogResult result = kDialogCancel;
+
+	const Common::String utf8Title = title.encode();
+	QString qTitle = QString::fromUtf8(utf8Title.c_str());
+
+	QString startPath;
+	if (ConfMan.hasKey("browser_lastpath")) {
+		const Common::String native = ConfMan.getPath("browser_lastpath").toString(Common::Path::kNativeSeparator);
+		startPath = QString::fromUtf8(native.c_str());
+	}
+
+	// Let Qt/desktop use the user locale for localized folder names.
+	setlocale(LC_ALL, "");
+
+	beginDialog();
+
+	// Keep the ScummVM window responsive while the modal dialog is open.
+	QTimer pump;
+	QObject::connect(&pump, &QTimer::timeout, []() {
+		Common::Event dummy;
+		while (g_system->getEventManager()->pollEvent(dummy)) {
+		}
+		g_system->updateScreen();
+	});
+	pump.start(16);
+
+	QFileDialog dialog(nullptr, qTitle, startPath);
+	if (isDirBrowser) {
+		dialog.setFileMode(QFileDialog::Directory);
+		dialog.setOption(QFileDialog::ShowDirsOnly, true);
+	} else {
+		dialog.setFileMode(QFileDialog::ExistingFile);
+	}
+
+	// Mirror the GTK backend's hidden-files preference when using Qt's
+	// non-native dialog. Native dialogs usually expose their own control.
+	if (ConfMan.getBool("gui_browser_show_hidden", Common::ConfigManager::kApplicationDomain)) {
+		dialog.setFilter(dialog.filter() | QDir::Hidden | QDir::System);
+	}
+
+	dialog.setLabelText(QFileDialog::Accept, QString::fromUtf8(_("Choose").encode().c_str()));
+	dialog.setLabelText(QFileDialog::Reject, QString::fromUtf8(_("Cancel").encode().c_str()));
+
+	if (dialog.exec() == QDialog::Accepted) {
+		const QStringList files = dialog.selectedFiles();
+		if (!files.isEmpty()) {
+			const QByteArray pathUtf8 = files.first().toUtf8();
+			Common::Path path(pathUtf8.constData(), Common::Path::kNativeSeparator);
+			choice = Common::FSNode(path);
+			ConfMan.setPath("browser_lastpath", path);
+			result = kDialogOk;
+		}
+	}
+
+	pump.stop();
+
+	// Restore default C locale (see bugs #6434 and #14196).
+	setlocale(LC_ALL, "C");
+
+	// Drain any residual Qt events so they do not stick around.
+	app->processEvents();
+
+	endDialog();
+	return result;
+}
+
+#endif
